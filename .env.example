# Previous provider example:
# SEEDANCE_API_KEY=replace-with-your-ephone-api-key
# SEEDANCE_BASE_URL=https://api.ephone.ai/v1

# Active provider example:
SEEDANCE_API_KEY=replace-with-your-apiqik-api-key
SEEDANCE_BASE_URL=https://value.apiqik.online/v1
SEEDANCE_DEFAULT_PROVIDER=apiqik
SEEDANCE_MODEL=happyhorse-1.0-t2v
SEEDANCE_PROVIDER_EPHONE_API_KEY=replace-with-your-ephone-api-key
SEEDANCE_PROVIDER_EPHONE_BASE_URL=https://api.ephone.ai/v1
SEEDANCE_PROVIDER_APIQIK_API_KEY=replace-with-your-apiqik-api-key
SEEDANCE_PROVIDER_APIQIK_BASE_URL=https://value.apiqik.online/v1
SEEDANCE_PROVIDER_APIQIK_SUBMIT_PATH=/videos
SEEDANCE_PROVIDER_APIQIK_QUERY_PATH_PREFIX=/videos/
PORT=3000
POLL_INTERVAL_MS=3000
ALLOWED_ORIGIN=
PUBLIC_BASE_URL=
OSS_REGION=oss-cn-shanghai
OSS_BUCKET=qzking
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=replace-with-your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=replace-with-your-oss-access-key-secret
OSS_PATH_PREFIX=seedance-assets/
OSS_PUBLIC_BASE_URL=https://qzking.oss-cn-shanghai.aliyuncs.com
